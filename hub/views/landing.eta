<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Sprint Suite — Agile tools for teams that ship</title>
<meta name="description" content="One sign-in, four focused apps for scrum masters and delivery leads. RAID logs, team health checks, retrospectives and planning poker.">
<link rel="canonical" href="https://sprintsuite.uk/">
<meta property="og:title" content="Sprint Suite — Agile tools for teams that ship">
<meta property="og:description" content="One sign-in, four focused apps for scrum masters and delivery leads.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://sprintsuite.uk/">
<meta property="og:image" content="https://sprintsuite.uk/img/og.png">
<meta name="twitter:card" content="summary_large_image">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon-32.png" sizes="32x32">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="stylesheet" href="/css/instrument-core.css">
<link rel="stylesheet" href="/css/landing.css">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"SoftwareApplication","name":"Sprint Suite","applicationCategory":"BusinessApplication","operatingSystem":"Web","description":"One sign-in, four focused apps for scrum masters and delivery leads.","url":"https://sprintsuite.uk/","offers":{"@type":"Offer","price":"0","priceCurrency":"GBP"},"featureList":["RAID log","Team health check","Sprint retrospective","Scrum planning poker"]}
</script>
<script type="module" src="/js/landing-hero.js"></script>
</head>
<body class="ins">

<header class="topbar lp-topbar">
  <a class="brand" href="/" aria-label="Sprint Suite"><svg class="mk" width="22" height="22" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-suite"/></svg> <span>Sprint<span class="brand-suite">Suite</span></span></a>
  <a class="btn btn-pri" href="<%= it.signinUrl %>">Sign in</a>
</header>

<section class="band lp-band">
  <div class="waves" aria-hidden="true"><svg viewBox="0 0 2400 200" preserveAspectRatio="none" width="100%" height="100%"><g class="waves-drift" id="scope"></g></svg></div>
  <div class="band-scrim" aria-hidden="true"></div>
  <div class="band-in lp-hero">
    <p class="eyebrow">Five tools · one passwordless login</p>
    <h1>Your agile toolkit, one login.</h1>
    <p class="lede lp-lede">For scrum masters and delivery leads who would rather run the sprint than manage another tool. One passwordless sign-in covers all of it. No setup, no sprawl.</p>
    <div class="cta-row">
      <a class="btn btn-pri btn-lg" href="<%= it.requestUrl %>">Get free access</a>
      <a class="btn btn-ghost btn-lg" href="<%= it.signinUrl %>">Sign in</a>
      <span class="cta-note">New here? Start free, no card. Returning? Sign in. Passwordless.</span>
    </div>
  </div>
</section>

<div class="trust">
  <div class="trust-in">
    <span class="trust-item"><span class="dot"></span> Passwordless sign-in</span>
    <span class="trust-item"><span class="dot"></span> Anonymous health checks</span>
    <span class="trust-item"><span class="dot"></span> Exports to Jira, CSV &amp; Markdown</span>
    <span class="trust-item"><span class="dot"></span> No tracking, no clutter</span>
  </div>
</div>

<main class="wrap">

<section class="section appgrid-section">
  <h2 class="sec-h">Five tools behind one login.</h2>
  <div class="appgrid">
    <a class="appcard" data-app="raid" href="<%= it.signinUrl %>">
      <span class="tile"><svg width="26" height="26" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-raid"/></svg></span>
      <div class="appcard-body">
        <h3>Sprintraid <span class="tag tag-raid">RAID</span></h3>
        <p>Risks, assumptions, issues and dependencies. Paste in email or Teams text, get a structured RAID log.</p>
      </div>
    </a>
    <a class="appcard" data-app="signal" href="<%= it.signinUrl %>">
      <span class="tile"><svg width="26" height="26" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-signal"/></svg></span>
      <div class="appcard-body">
        <h3>Sprintsignal <span class="tag tag-signal">Health</span></h3>
        <p>Run a team health check and surface what's working and what isn't, anonymously.</p>
      </div>
    </a>
    <a class="appcard" data-app="retro" href="<%= it.signinUrl %>">
      <span class="tile"><svg width="26" height="26" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-retro"/></svg></span>
      <div class="appcard-body">
        <h3>Sprintretro <span class="tag tag-retro">Retro</span></h3>
        <p>Fast sprint retrospectives with Start / Stop / Continue boards and a built-in timer.</p>
      </div>
    </a>
    <a class="appcard" data-app="poker" href="<%= it.signinUrl %>">
      <span class="tile"><svg width="26" height="26" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-poker"/></svg></span>
      <div class="appcard-body">
        <h3>Sprintpoker <span class="tag tag-poker">Estimate</span></h3>
        <p>Planning poker for estimating your backlog together, no accounts needed for guests.</p>
      </div>
    </a>
    <div class="appcard" data-app="plan">
      <span class="tile"><svg width="26" height="26" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-plan"/></svg></span>
      <div class="appcard-body">
        <h3>Sprintplan <span class="tag tag-plan">Free</span></h3>
        <p>Map a delivery roadmap sprint by sprint. Drag stories into sprints, watch capacity, flag dependencies. Runs in your browser, no account needed.</p>
      </div>
    </div>
  </div>
</section>

<section class="features" id="features" aria-label="App features">
  <div class="frow" data-app="raid">
    <div class="ftext">
      <p class="frow-eyebrow">Sprintraid</p>
      <h3>Turn meeting noise into a clean RAID log.</h3>
      <p>Paste an email or Teams thread and Sprintraid extracts a structured RAID log (risks, assumptions, issues and dependencies) so nothing slips between sprints.</p>
      <ul class="flist">
        <li>Auto-classify risks, assumptions, issues &amp; dependencies</li>
        <li>Flags dependency conflicts across workstreams</li>
        <li>Export to Jira, CSV or Markdown</li>
      </ul>
    </div>
    <figure class="shot">
      <div class="chrome" aria-hidden="true"><i></i><i></i><i></i><span class="url">sprintraid.uk</span></div>
      <picture>
        <source type="image/webp" srcset="/img/shot-raid.webp 1x, /img/shot-raid@2x.webp 2x">
        <img src="/img/shot-raid.png" width="1180" height="865" loading="lazy" decoding="async"
          alt="Sprintraid RAID log with risks, assumptions, issues and a flagged dependency conflict">
      </picture>
    </figure>
  </div>

  <div class="frow" data-app="signal">
    <div class="ftext">
      <p class="frow-eyebrow">Sprintsignal</p>
      <h3>Run a team health check in minutes.</h3>
      <p>See where the team actually stands. An anonymous health check plots focus areas on a radar over time, so you can spot what is thriving and what needs support before it bites.</p>
      <ul class="flist">
        <li>Anonymous submissions, honest signal</li>
        <li>Radar chart of focus areas over time</li>
        <li>Share read-only results with stakeholders</li>
      </ul>
    </div>
    <figure class="shot">
      <div class="chrome" aria-hidden="true"><i></i><i></i><i></i><span class="url">sprintsignal.uk</span></div>
      <picture>
        <source type="image/webp" srcset="/img/shot-signal.webp 1x, /img/shot-signal@2x.webp 2x">
        <img src="/img/shot-signal.png" width="1090" height="475" loading="lazy" decoding="async"
          alt="Sprintsignal health check radar chart and focus areas">
      </picture>
    </figure>
  </div>

  <div class="frow" data-app="retro">
    <div class="ftext">
      <p class="frow-eyebrow">Sprintretro</p>
      <h3>Retrospectives that don't drag.</h3>
      <p>Keep the retro moving and end with clear actions. A Start / Stop / Continue board, live stat cards and a built-in timer do the steering, so the conversation lands instead of drifting.</p>
      <ul class="flist">
        <li>Start / Stop / Continue board</li>
        <li>Live stat cards and a built-in timer</li>
        <li>Disposable rooms, share a link, no accounts for guests</li>
      </ul>
    </div>
    <figure class="shot">
      <div class="chrome" aria-hidden="true"><i></i><i></i><i></i><span class="url">sprintretro.uk</span></div>
      <picture>
        <source type="image/webp" srcset="/img/shot-retro.webp 1x, /img/shot-retro@2x.webp 2x">
        <img src="/img/shot-retro.png" width="1200" height="517" loading="lazy" decoding="async"
          alt="Sprintretro Start Stop Continue board with stat cards and timer">
      </picture>
    </figure>
  </div>

  <div class="frow" data-app="poker">
    <div class="ftext">
      <p class="frow-eyebrow">Sprintpoker</p>
      <h3>Estimate together with scrum poker.</h3>
      <p>Estimate as a team without anchoring. Everyone votes face-down, then reveals together, so the numbers stay honest and the discussion stays on the story, not the loudest voice.</p>
      <ul class="flist">
        <li>Face-down voting, reveal together</li>
        <li>Guests join with a link, no account needed</li>
        <li>Bring your own backlog items</li>
      </ul>
    </div>
    <figure class="shot">
      <div class="chrome" aria-hidden="true"><i></i><i></i><i></i><span class="url">sprintpoker.uk</span></div>
      <picture>
        <source type="image/webp" srcset="/img/shot-poker.webp 1x, /img/shot-poker@2x.webp 2x">
        <img src="/img/shot-poker.png" width="738" height="220" loading="lazy" decoding="async"
          alt="Sprintpoker estimation room with face-up and face-down cards">
      </picture>
    </figure>
  </div>

  <div class="frow" data-app="plan">
    <div class="ftext">
      <p class="frow-eyebrow"><svg class="frow-mk" width="14" height="14" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-plan"/></svg>Sprintplan · Free, no sign-in</p>
      <h3>Plan the whole roadmap, sprint by sprint.</h3>
      <p>Sprintplan is a lightweight delivery board: set your cadence, drag stories into sprints, and see capacity and cross-sprint dependencies as you go. It runs entirely in your browser, with no account and no backend, and your plan saves locally.</p>
      <ul class="flist">
        <li>Drag stories into sprints with live capacity</li>
        <li>Flag and track cross-sprint dependencies</li>
        <li>Export a plan summary to Markdown, HTML or CSV</li>
      </ul>
    </div>
    <figure class="shot">
      <div class="chrome" aria-hidden="true"><i></i><i></i><i></i><span class="url">sprintplan.uk</span></div>
      <picture>
        <source type="image/webp" srcset="/img/shot-plan.webp 1x, /img/shot-plan@2x.webp 2x">
        <img src="/img/shot-plan.png" width="1240" height="947" loading="lazy" decoding="async"
          alt="Sprintplan delivery board with stories placed across sprints, a capacity nudge and a dependency badge">
      </picture>
    </figure>
  </div>
</section>

<section class="faq" id="faq">
  <h2 class="sec-h">Questions</h2>
  <div class="qa"><h3>Is it really free?</h3><p>Yes. Sign in and use all five tools without paying, no card and no trial clock. A few apps cap heavy usage or AI calls, so it is not unlimited, but everyday team use is covered.</p></div>
  <div class="qa"><h3>Do I need a password?</h3><p>No. Sign-in is a passwordless magic link sent to your email. The same link both signs you up and signs you in.</p></div>
  <div class="qa"><h3>Do my guests need accounts?</h3><p>No. Retrospectives and planning poker rooms can be shared with a link, so guests join without creating an account.</p></div>
  <div class="qa"><h3>Where does my data go?</h3><p>Your data stays in Sprint Suite. There's no third-party tracking, and health-check submissions are anonymous.</p></div>
  <div class="qa"><h3>Can I export?</h3><p>Yes. RAID logs export to Jira, CSV and Markdown so your work doesn't get stuck in another tool.</p></div>
</section>

<section class="close">
  <h2>Run your next sprint from one login.</h2>
  <p>Get free access for your team in a couple of clicks. Passwordless, no card, no setup, no sprawl.</p>
  <div class="cta-row">
    <a class="btn btn-pri btn-lg" href="<%= it.requestUrl %>">Get free access</a>
    <a class="btn btn-ghost btn-lg" href="<%= it.signinUrl %>">Sign in</a>
  </div>
</section>

</main>

<footer class="lp-footer">
  <div class="lp-footer-in">
    <div class="lp-foot-lead">
      <a class="brand" href="/" aria-label="Sprint Suite"><svg class="mk" width="20" height="20" aria-hidden="true"><use href="/illos/glyphs.svg#glyph-suite"/></svg> <span>Sprint<span class="brand-suite">Suite</span></span></a>
      <p>Five focused agile tools for scrum masters and delivery leads, behind one passwordless login.</p>
    </div>
    <nav class="lp-foot-col" aria-label="Apps">
      <p class="lp-foot-h">Apps</p>
      <a href="<%= it.signinUrl %>">Sprintraid</a>
      <a href="<%= it.signinUrl %>">Sprintsignal</a>
      <a href="<%= it.signinUrl %>">Sprintretro</a>
      <a href="<%= it.signinUrl %>">Sprintpoker</a>
    </nav>
    <nav class="lp-foot-col" aria-label="Product">
      <p class="lp-foot-h">Product</p>
      <a href="#features">Features</a>
      <a href="#faq">FAQ</a>
      <a href="<%= it.requestUrl %>">Request access</a>
      <a href="<%= it.signinUrl %>">Sign in</a>
    </nav>
    <nav class="lp-foot-col" aria-label="Legal">
      <p class="lp-foot-h">Legal</p>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/license">License</a>
    </nav>
  </div>
  <div class="lp-foot-bar">
    <span>© 2026 Sprint Suite</span>
    <span class="mono">sprintsuite.uk</span>
  </div>
</footer>

</body>
</html>
